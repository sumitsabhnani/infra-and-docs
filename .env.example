# ──────────────────────────────────────────────────────────────────────────────
# Portfolio Optimizer — server environment
# Copy to `.env` on the Ubuntu host and fill in every value. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────────

# ── Postgres (container-local DB) ─────────────────────────────────────────────
POSTGRES_DB=portfolio_db
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Public base URL used in outbound email links ──────────────────────────────
APP_BASE_URL=https://your.domain.example

# ── CORS allowed origins (comma-separated, no spaces, no trailing slash) ──────
# Include every public origin the SPA is served from. Even with same-origin
# routing through nginx, Spring may still see cross-origin if upstream proxies
# alter scheme/host headers — list both apex and www.
APP_CORS_ALLOWED_ORIGINS=https://your.domain.example,https://www.your.domain.example

# ── JWT + field encryption (generate with `openssl rand -base64 64` / `32`) ───
JWT_SECRET=CHANGE_ME_BASE64_64_BYTES
ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES
INTERNAL_ADMIN_TOKEN=CHANGE_ME_RANDOM

# ── OAuth providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── Broker + market data ──────────────────────────────────────────────────────
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_REDIRECT_URI=https://your.domain.example/integrations/snaptrade/callback
ALPHA_VANTAGE_API_KEY=
EODHD_API_KEY=
OPENFIGI_API_KEY=
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
BHAVKOSH_API_KEY=

# ── AI / notifications / storage ──────────────────────────────────────────────
GOOGLE_AI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_ADDRESS=admin@your.domain.example
SLACK_WEBHOOK_URL=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=
